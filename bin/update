#!/usr/bin/env bash
set -e

if command -v mise >/dev/null 2>&1; then
  ruby_version=$(tr -d '\n' < "$(dirname "$0")/../.ruby-version")
  ruby_version=${ruby_version#ruby-}
  ruby_root=$(mise where "ruby@${ruby_version}" 2>/dev/null || true)
  if [ -n "$ruby_root" ] && [ -x "$ruby_root/bin/ruby" ]; then
    exec "$ruby_root/bin/ruby" -x "$0" "$@"
  fi
fi

exec ruby -x "$0" "$@"
#!/usr/bin/env ruby
# frozen_string_literal: true

require "fileutils"
require "open3"
require "rbconfig"

APP_ROOT = File.expand_path("..", __dir__)

Step = Struct.new(:label, :command, :env, keyword_init: true)

STEPS = [
  Step.new(label: "Updating gems", command: %w[bundle update --all]),
  Step.new(label: "Updating Bundler lock", command: %w[bundle update --bundler]),
  Step.new(label: "Updating Ruby lock", command: %w[bundle update --ruby]),
  Step.new(label: "Updating npm packages", command: %w[npm update]),
  Step.new(label: "Updating DaisyUI", command: %w[npm install --save-dev --save-exact daisyui@latest]),
  Step.new(label: "Updating importmap packages", command: %w[bin/importmap update]),
  Step.new(label: "Preparing database", command: %w[bin/rails db:prepare]),
  Step.new(label: "Clearing logs and temporary files", command: %w[bin/rails log:clear tmp:clear])
].freeze

def expected_ruby
  File.read(".ruby-version").strip.delete_prefix("ruby-")
end

def bundle_command(command)
  return command unless command.first.start_with?("bin/")

  [ RbConfig.ruby, "-S", "bundle", "exec", *command ]
end

def format_duration(seconds)
  minutes = (seconds / 60).to_i
  format("%02d:%05.2f", minutes, seconds - (minutes * 60))
end

def run(step)
  started_at = Process.clock_gettime(Process::CLOCK_MONOTONIC)
  puts "\n\e[1;35m▸ #{step.label}\e[0m"
  success = system(step.env || {}, *bundle_command(step.command))
  seconds = Process.clock_gettime(Process::CLOCK_MONOTONIC) - started_at
  { label: step.label, status: success ? "PASS" : "FAIL", seconds: seconds }
end

def print_summary(results)
  step_width = [ results.map { |result| result[:label].length }.max || 4, 4 ].max
  divider = "+-#{'-' * step_width}-+--------+----------+"

  puts "\nUpdate summary"
  puts divider
  puts "| #{'Step'.ljust(step_width)} | Result |     Time |"
  puts divider
  results.each do |result|
    puts "| #{result[:label].ljust(step_width)} | #{result[:status].ljust(6)} | #{format_duration(result[:seconds]).rjust(8)} |"
  end
  puts divider
end

FileUtils.chdir(APP_ROOT) do
  unless RUBY_VERSION == expected_ruby
    abort "Ruby #{expected_ruby} required (using #{RUBY_VERSION})"
  end

  ruby_bin = File.dirname(RbConfig.ruby)
  ENV["PATH"] = "#{ruby_bin}:#{ENV.fetch('PATH')}" unless ENV.fetch("PATH").split(":").include?(ruby_bin)

  results = []
  STEPS.each do |step|
    result = run(step)
    results << result
    break if result[:status] == "FAIL"
  end

  print_summary(results)
  abort "\nUpdate failed." unless results.length == STEPS.length && results.all? { |result| result[:status] == "PASS" }

  FileUtils.touch("tmp/restart.txt")
  puts "\n\e[1;32m✓ Update complete\e[0m"
  puts "Next: git diff && bin/quality"
end
