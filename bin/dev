#!/usr/bin/env sh

if ! gem list foreman -i --silent; then
  echo "Installing foreman..."
  gem install foreman
fi

# Run beside the production server on 3100 instead of clashing with it.
export PORT="${PORT:-3200}"

# Hosted agents reach this server through host.containers.internal, so bind
# every interface rather than loopback only.
export BINDING="${BINDING:-0.0.0.0}"

# Let the debug gem allow remote connections,
# but avoid loading until `debugger` is called
export RUBY_DEBUG_OPEN="true"
export RUBY_DEBUG_LAZY="true"

exec foreman start -f Procfile.dev "$@"
