<% content_for :title, "Projects · Zuwerk" %>

<section class="project-directory" aria-labelledby="projects-title">
  <header class="project-directory-header">
    <div>
      <p class="projects-overview-eyebrow">Workspace</p>
      <h1 id="projects-title">Projects</h1>
      <p>Choose a project to see its shared work.</p>
    </div>

    <details class="projects-create">
      <summary>New project</summary>
      <div class="projects-create-popover">
        <%= form_with model: Project.new, url: projects_path do |form| %>
          <%= form.label :name, "Project name" %>
          <div>
            <%= form.text_field :name, required: true, maxlength: 80, placeholder: "Project name" %>
            <%= form.submit "Create" %>
          </div>
        <% end %>
      </div>
    </details>
  </header>

  <% if @projects.any? %>
    <div class="project-directory-grid">
      <% @projects.each do |project| %>
        <% open_count = project.todos.count(&:open?) %>
        <% in_progress_count = project.todos.count(&:in_progress?) %>
        <article class="project-directory-card" data-project-id="<%= project.id %>">
          <%= link_to project_path(project), class: "project-directory-link" do %>
            <span class="project-directory-mark" aria-hidden="true"><%= project.name.first.upcase %></span>
            <span class="project-directory-copy">
              <strong><%= project.name %></strong>
              <span><%= pluralize(open_count, "open task") %> · <%= in_progress_count %> in progress</span>
            </span>
            <span class="project-directory-arrow" aria-hidden="true">→</span>
          <% end %>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="project-overview-empty">
      <h2>Create your first project</h2>
      <p>Give work a home, then add tasks and conversations.</p>
    </div>
  <% end %>
</section>
