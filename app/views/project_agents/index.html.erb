<% content_for :title, "Agents · #{@project.name} · Zuwerk" %>
<section class="project-agents-page">
  <nav class="workspace-breadcrumb" aria-label="Breadcrumb"><%= link_to @project.name, project_path(@project) %><span aria-hidden="true">/</span><span aria-current="page">Agents</span></nav>
  <header class="project-agents-header"><div><p class="project-agents-kicker">Project runtimes</p><h1>Agents</h1><p>Open up to 20 independent, persistent tmux terminals per hosted agent for direct project access.</p></div></header>

  <section class="project-agent-list" aria-labelledby="available-agents-heading">
    <div class="board-section-heading"><h2 id="available-agents-heading">Available agents</h2></div>
    <% @hosted_agents.each do |hosted| %>
      <article class="project-agent-card" data-agent-id="<%= hosted.user_id %>">
        <div class="project-agent-identity"><span class="project-avatar" aria-hidden="true"><%= hosted.user.name.first.upcase %></span><span><strong><%= hosted.user.name %></strong><small><%= hosted.runtime.humanize %> · <%= hosted.state.humanize %></small></span></div>
        <%= form_with model: [ @project, AgentTerminalPane.new ], class: "project-pane-form" do |form| %>
          <%= form.hidden_field :hosted_agent_id, value: hosted.id %>
          <% pane_name_id = "agent_terminal_pane_name_#{hosted.id}" %>
          <%= form.label :name, "Pane name for #{hosted.user.name}", for: pane_name_id, class: "sr-only" %>
          <%= form.text_field :name, id: pane_name_id, required: true, maxlength: 80, placeholder: "Pane name", disabled: !hosted.running?, class: "input input-bordered bg-white" %>
          <%= form.submit "Spawn pane", disabled: !hosted.running?, class: "btn btn-outline" %>
        <% end %>
      </article>
    <% end %>
    <% if @hosted_agents.empty? %><div class="files-empty"><strong>No hosted agents yet.</strong><p>Create a hosted agent before opening direct terminals.</p></div><% end %>
  </section>

  <section class="project-pane-list" aria-labelledby="terminal-panes-heading">
    <div class="board-section-heading"><h2 id="terminal-panes-heading">Terminal panes</h2><small><%= pluralize(@panes.size, "pane") %></small></div>
    <% @panes.each do |pane| %>
      <details class="agent-terminal-disclosure project-pane" id="pane_<%= pane.id %>">
        <summary><span class="agent-terminal-summary-copy"><strong><%= pane.name %></strong><small><%= pane.hosted_agent.user.name %> · persistent tmux window</small></span><i aria-hidden="true">⌄</i></summary>
        <div class="agent-terminal-disclosure-body">
          <div class="terminal-cockpit" data-terminal-agent-id="<%= pane.hosted_agent.user_id %>" data-terminal-project-id="<%= @project.id %>" data-terminal-pane-id="<%= pane.id %>" data-terminal-enabled="<%= pane.hosted_agent.running? %>">
            <div class="terminal-titlebar"><div><i></i><i></i><i></i></div><span><%= pane.name %> · <%= pane.hosted_agent.runtime %></span><button type="button" data-terminal-reconnect>Reconnect</button></div>
            <div class="terminal-screen terminal-screen-compact" data-terminal-screen tabindex="0" aria-label="Interactive terminal for <%= pane.name %>"></div>
          </div>
          <div class="project-pane-footer"><span>Created by <%= pane.creator.name %></span><%= button_to "Close pane", project_agent_terminal_pane_path(@project, pane), method: :delete, class: "file-delete", form: { data: { turbo_confirm: "Close this terminal pane? Its tmux window will be terminated." } } %></div>
        </div>
      </details>
    <% end %>
    <% if @panes.empty? %><div class="files-empty"><strong>No direct terminals open.</strong><p>Spawn a pane for any running hosted agent.</p></div><% end %>
  </section>
</section>
