<% content_for :title, "#{@todo.title} · Todos · Zuwerk" %>
<%= turbo_stream_from "todo_#{@todo.id}_status" %>
<section class="todo-detail-page">
  <%= link_to "← Zurück zum Board", project_todos_path(@project), class: "workspace-back-link" %>
  <div class="todo-detail-shell">
    <header class="todo-detail-header">
      <div class="todo-detail-heading">
        <div class="todo-detail-eyebrow"><span>TODO #<%= @todo.id %></span><span class="todo-status todo-status-<%= @todo.status.dasherize %>"><%= { "open" => "Offen", "in_progress" => "In Arbeit", "completed" => "Erledigt" }.fetch(@todo.status) %></span></div>
        <h1><%= @todo.title %></h1><%= render "todos/agent_acknowledgements", todo: @todo %>
      </div>
      <div class="todo-detail-actions"><%= button_to(@todo.completed? ? "Wieder öffnen" : "Erledigen", project_todo_path(@project, @todo), method: :patch, params: { todo: { status: @todo.completed? ? "open" : "completed" } }, class: "workspace-secondary-action") %><%= link_to "Bearbeiten", edit_project_todo_path(@project, @todo), class: "workspace-primary-action" %></div>
      <% if @todo.description.present? %><div class="todo-description lexxy-content"><%= @todo.description %></div><% end %>
    </header>
    <div class="todo-detail-grid">
      <section class="todo-conversation" aria-labelledby="comments-heading">
        <div class="todo-section-heading"><h2 id="comments-heading">Aktivität</h2><span><%= @todo.comments.count %></span></div>
        <div class="todo-comments"><%= render partial: "todo_comments/comment", collection: @todo.comments.includes(:author, :rich_text_body, reactions: :author).order(:created_at) %></div>
        <%= form_with model: @comment, url: project_todo_comments_path(@project, @todo), class: "todo-comment-form" do |form| %><% if @comment.errors.any? %><p class="mb-2 text-sm text-red-600"><%= @comment.errors.full_messages.to_sentence %></p><% end %><%= form.rich_text_area :body, placeholder: "Update, Entscheidung oder Kontext hinzufügen…" %><div class="mt-3 flex justify-end"><%= form.submit "Kommentar hinzufügen", class: "workspace-primary-action" %></div><% end %>
      </section>
      <aside class="todo-properties">
        <section><h2>Status</h2><div class="todo-status-options"><% [["open", "Offen"], ["in_progress", "In Arbeit"], ["completed", "Erledigt"]].each do |status, label| %><%= button_to label, project_todo_path(@project, @todo), method: :patch, params: { todo: { status: status } }, class: "todo-status-option #{'todo-status-option-active' if @todo.status == status}" %><% end %></div></section>
        <section><h2>Zugewiesen</h2><div class="todo-agent-list"><% @todo.assignments.includes(:agent).each do |assignment| %><div><span class="todo-agent-avatar"><%= assignment.agent.name.first.upcase %></span><strong><%= assignment.agent.name %></strong><%= button_to "×", project_todo_assignment_path(@project, @todo, assignment), method: :delete, title: "Agent entfernen" %></div><% end %></div><% available_agents = @agents.where.not(id: @todo.assigned_agent_ids) %><% if available_agents.any? %><%= form_with url: project_todo_assignments_path(@project, @todo), class: "todo-agent-form" do |form| %><%= form.collection_select :agent_id, available_agents, :id, :name, {}, class: "select select-bordered select-sm min-w-0 flex-1 bg-white" %><%= form.submit "Zuweisen", class: "workspace-secondary-action" %><% end %><% end %></section>
        <section><h2>Kontext</h2><dl class="todo-context-list"><% if @todo.parent %><div><dt>Übergeordnet</dt><dd><%= link_to @todo.parent.title, project_todo_path(@project, @todo.parent) %></dd></div><% end %><div><dt>Erstellt von</dt><dd><%= @todo.creator.name %></dd></div><div><dt>Erstellt</dt><dd><%= @todo.created_at.strftime("%d.%m.%Y") %></dd></div></dl></section>
      </aside>
    </div>
  </div>
</section>