<% content_for :title, "#{@todo.title} · Todos · Zuwerk" %>

<section class="mx-auto max-w-[1500px]">
  <div class="grid items-start gap-6 lg:grid-cols-[250px_minmax(0,1fr)]">
    <%= render "todos/navigation" %>

    <div class="min-w-0 rounded-xl border border-stone-200 bg-white">
      <header class="border-b border-stone-200 px-5 py-5 sm:px-7">
        <div class="flex flex-wrap items-start gap-3">
          <div class="min-w-0 flex-1">
            <p class="mb-1 text-xs font-semibold uppercase tracking-[.12em] text-stone-400"><%= @project.name %> · Todo #<%= @todo.id %></p>
            <h1 class="text-2xl font-semibold tracking-tight text-stone-950"><%= @todo.title %></h1>
          </div>
          <%= button_to(@todo.completed? ? "Reopen" : "Complete", project_todo_path(@project, @todo), method: :patch, params: { todo: { status: @todo.completed? ? "open" : "completed" } }, class: "btn btn-sm btn-outline") %>
          <%= link_to "Edit", edit_project_todo_path(@project, @todo), class: "btn btn-sm btn-ghost" %>
        </div>
        <% if @todo.description.present? %><div class="lexxy-content mt-5 text-stone-700"><%= @todo.description %></div><% end %>
      </header>

      <div class="grid gap-8 p-5 sm:p-7 xl:grid-cols-[minmax(0,1fr)_240px]">
        <section class="min-w-0" aria-labelledby="comments-heading">
          <h2 id="comments-heading" class="text-sm font-semibold text-stone-900">Comments <span class="font-normal text-stone-400"><%= @todo.comments.count %></span></h2>
          <div class="mt-2">
            <%= render partial: "todo_comments/comment", collection: @todo.comments.includes(:author, :rich_text_body).order(:created_at) %>
          </div>
          <%= form_with model: @comment, url: project_todo_comments_path(@project, @todo), class: "mt-6 border-t border-stone-200 pt-6" do |form| %>
            <% if @comment.errors.any? %><p class="mb-2 text-sm text-red-600"><%= @comment.errors.full_messages.to_sentence %></p><% end %>
            <%= form.rich_text_area :body, placeholder: "Add context, an update, files or a decision…" %>
            <div class="mt-3 flex justify-end"><%= form.submit "Add comment", class: "btn btn-sm bg-stone-900 text-white hover:bg-stone-700" %></div>
          <% end %>
        </section>

        <aside class="space-y-6 border-t border-stone-200 pt-6 xl:border-l xl:border-t-0 xl:pl-6 xl:pt-0">
          <section>
            <h2 class="text-xs font-semibold uppercase tracking-[.12em] text-stone-400">Agents</h2>
            <div class="mt-3 space-y-2">
              <% @todo.assignments.includes(:agent).each do |assignment| %>
                <div class="flex items-center justify-between text-sm"><span><%= assignment.agent.name %></span><%= button_to "×", project_todo_assignment_path(@project, @todo, assignment), method: :delete, class: "text-stone-400 hover:text-red-600", title: "Remove agent" %></div>
              <% end %>
              <% available_agents = @agents.where.not(id: @todo.assigned_agent_ids) %>
              <% if available_agents.any? %>
                <%= form_with url: project_todo_assignments_path(@project, @todo), class: "flex gap-2" do |form| %>
                  <%= form.collection_select :agent_id, available_agents, :id, :name, {}, class: "select select-bordered select-sm min-w-0 flex-1 bg-white" %>
                  <%= form.submit "Assign", class: "btn btn-sm btn-outline" %>
                <% end %>
              <% end %>
            </div>
          </section>
          <section class="text-xs text-stone-500">
            <h2 class="mb-2 font-semibold uppercase tracking-[.12em] text-stone-400">Context</h2>
            <% @todo.ancestors.each do |ancestor| %><p class="truncate">↳ <%= ancestor.title %></p><% end %>
            <p>Created by <%= @todo.creator.name %></p>
            <p><%= @todo.created_at.strftime("%d.%m.%Y · %H:%M") %></p>
          </section>
        </aside>
      </div>
    </div>
  </div>
</section>
