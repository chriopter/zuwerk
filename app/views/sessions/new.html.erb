<section class="auth-card"><p class="eyebrow">WELCOME BACK</p><h1>Sign in</h1><%= form_with url: session_path do |form| %><%= form.label :email %><%= form.email_field :email, required: true, autofocus: true %><%= form.label :password %><%= form.password_field :password, required: true %><%= form.submit "Sign in", class: "primary" %><% end %></section>