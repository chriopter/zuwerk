<section class="auth-card"><p class="eyebrow">FIRST RUN</p><h1>Create your workspace</h1><p>Set up the first human administrator.</p><%= form_with model: @user, url: onboarding_path do |form| %><%= render "shared/errors", object: @user %><%= form.label :name %><%= form.text_field :name, required: true, autofocus: true %><%= form.label :email %><%= form.email_field :email, required: true %><%= form.label :password %><%= form.password_field :password, required: true, minlength: 8 %><%= form.label :password_confirmation %><%= form.password_field :password_confirmation, required: true %><%= form.submit "Create workspace", class: "primary" %><% end %></section>