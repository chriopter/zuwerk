<% content_for :title, "#{@post.title} · Board · #{@project.name} · Zuwerk" %>

<article class="board-post-page">
  <nav class="workspace-breadcrumb" aria-label="Breadcrumb"><%= link_to @project.name, project_path(@project) %><span aria-hidden="true">/</span><%= link_to "Board", project_board_posts_path(@project) %><span aria-hidden="true">/</span><span aria-current="page"><%= @post.title %></span></nav>
  <header class="board-post-header">
    <h1><%= @post.title %></h1>
    <div class="board-post-meta"><span class="project-avatar project-avatar-small" aria-hidden="true"><%= @post.author.name.first.upcase %></span><span>Published by <%= @post.author.name %> for <%= link_to @post.board_automation.title, project_board_automation_path(@project, @post.board_automation) %> on <%= time_tag @post.published_at, @post.published_at.to_fs(:long) %></span></div>
  </header>
  <div class="board-post-body prose max-w-none"><%= @post.body %></div>
</article>
