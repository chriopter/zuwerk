<% content_for :title, "Board · #{@project.name} · Zuwerk" %>

<section class="board-page">
  <header class="board-page-header">
    <div>
      <nav class="workspace-breadcrumb" aria-label="Breadcrumb"><%= link_to @project.name, project_path(@project) %><span aria-hidden="true">/</span><span aria-current="page">Board</span></nav>
      <h1>Board</h1>
      <p>Recurring agent publications for this project.</p>
    </div>
    <%= link_to "New automation", new_project_board_automation_path(@project), class: "btn bg-stone-900 text-white hover:bg-stone-700" %>
  </header>

  <section class="board-automations" aria-labelledby="board-automations-title">
    <div class="board-section-heading">
      <h2 id="board-automations-title">Automations</h2>
      <span><%= @automations.count %></span>
    </div>
    <% if @automations.any? %>
      <div class="board-automation-list">
        <% @automations.each do |automation| %>
          <%= link_to project_board_automation_path(@project, automation), class: "board-automation-row" do %>
            <span class="project-avatar project-avatar-small" aria-hidden="true"><%= automation.agent.name.first.upcase %></span>
            <span class="board-automation-copy"><strong><%= automation.title %></strong><small><%= automation.agent.name %> · <%= automation.cadence_label %> · <%= automation.active? ? "Next #{time_ago_in_words(automation.next_run_at)} from now" : "Paused" %></small></span>
            <span class="board-automation-state <%= automation.active? ? 'is-active' : '' %>"><%= automation.active? ? "Active" : "Paused" %></span>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <p class="board-empty-compact">No recurring publications yet.</p>
    <% end %>
  </section>

  <section class="board-publications" aria-labelledby="board-publications-title">
    <div class="board-section-heading"><h2 id="board-publications-title">Publications</h2></div>
    <% if @posts.any? %>
      <div class="board-post-list">
        <% @posts.each do |post| %>
          <article class="board-post-entry">
            <div class="board-post-meta"><span class="project-avatar project-avatar-small" aria-hidden="true"><%= post.author.name.first.upcase %></span><span><%= post.author.name %> · <%= time_tag post.published_at, post.published_at.to_fs(:long) %></span></div>
            <h3><%= link_to post.title, project_board_post_path(@project, post) %></h3>
            <div class="board-post-excerpt"><%= truncate(post.body.to_plain_text.squish, length: 280) %></div>
            <%= link_to "Read post →", project_board_post_path(@project, post), class: "board-read-link" %>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="board-empty-state"><strong>No publications yet</strong><p>Create an automation or run one now. Its agent result will appear here.</p></div>
    <% end %>
  </section>
</section>
