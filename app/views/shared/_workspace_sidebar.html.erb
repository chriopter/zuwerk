<aside class="workspace-sidebar">
  <%= turbo_stream_from "agent_work" %>
  <%= render "shared/sidebar_project_tree", project: project, projects: projects, active: active %>

  <section class="sidebar-agents" aria-labelledby="agents-heading">
    <div class="sidebar-section-heading">
      <%= link_to "Agents", agents_path, id: "agents-heading", class: active == :agents ? "sidebar-heading-active" : nil %>
      <%= link_to "＋", new_agent_path, class: "sidebar-heading-action", aria: { label: "Create agent" }, title: "Create agent" %>
    </div>
    <%= render "shared/sidebar_agent_list", agents: agents, active_agent_id: active_agent_id %>
  </section>

  <div class="sidebar-footer">
    <div class="sidebar-footer-profile">
      <div class="sidebar-avatar sidebar-avatar-human"><%= current_user.name.first.upcase %></div>
      <div class="min-w-0 flex-1">
        <div class="truncate text-sm font-medium text-stone-800"><%= current_user.name %></div>
        <div class="text-xs text-stone-400">Signed in</div>
      </div>
      <div class="sidebar-footer-actions">
        <%= button_to "Log out", session_path, method: :delete, class: "sidebar-logout", title: "Log out", aria: { label: "Log out" } %>
        <% if current_user.admin? %><%= link_to "DB", database_path, class: "sidebar-db-link #{'sidebar-db-link-active' if active == :database}", aria: (active == :database ? { current: "page" } : {}) %><% end %>
      </div>
    </div>
  </div>
</aside>
