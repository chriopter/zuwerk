<aside class="workspace-sidebar">
  <%= render "messages/project_switcher", project: project, projects: projects %>

  <section class="sidebar-agents" aria-labelledby="agents-heading">
    <div class="sidebar-section-heading">
      <%= link_to "Agents", agents_path, id: "agents-heading", class: active == :agents ? "sidebar-heading-active" : nil %>
      <%= link_to "＋", new_agent_path, class: "sidebar-heading-action", aria: { label: "Create agent" }, title: "Create agent" %>
    </div>
    <div class="sidebar-agent-list">
      <% agents.each do |agent| %>
        <% hosted = agent.hosted_agent %>
        <% if hosted %>
          <% connected = hosted.bridge_connected? %>
          <% status = if connected
            "Connected"
          elsif hosted.running?
            "Runtime running · Not connected"
          else
            hosted.state.humanize
          end %>
          <% dot_class = connected ? "agent-dot-online" : (hosted.running? ? "agent-dot-runtime" : "agent-dot-offline") %>
        <% else %>
          <% connected = agent.working? %>
          <% status = connected ? (agent.working_label.presence || "Working") : "Offline" %>
          <% dot_class = connected ? "agent-dot-working" : "agent-dot-offline" %>
        <% end %>
        <%= link_to(hosted ? agent_path(agent) : agents_path, class: "agent-row #{'agent-row-active' if active_agent_id == agent.id}", data: { sidebar_agent_id: agent.id, agent_connected: connected }) do %>
          <div class="relative">
            <div class="sidebar-avatar"><%= agent.name.first.upcase %></div>
            <span class="agent-dot <%= dot_class %>"></span>
          </div>
          <div class="min-w-0 flex-1">
            <div class="truncate text-sm font-medium text-stone-800"><%= agent.name %></div>
            <div class="truncate text-xs text-stone-400"><%= status %></div>
          </div>
        <% end %>
      <% end %>
    </div>
    <%= link_to new_agent_invitation_path, class: "sidebar-invite" do %>
      <span aria-hidden="true">＋</span><span>Connect external agent</span>
    <% end %>
  </section>

  <nav class="sidebar-navigation" aria-label="Workspace navigation">
    <div class="sidebar-label">Conversation</div>
    <%= link_to chat_project_path(project), class: "sidebar-channel #{'sidebar-channel-active' if active == :chat}", aria: (active == :chat ? { current: "page" } : {}) do %>
      <span>Shared chat</span>
    <% end %>
  </nav>

  <% if current_user.admin? %>
    <nav class="sidebar-system-navigation" aria-label="System navigation">
      <div class="sidebar-label">System</div>
      <%= link_to database_path, class: "sidebar-channel #{'sidebar-channel-active' if active == :database}", aria: (active == :database ? { current: "page" } : {}) do %>
        <span>DB</span>
      <% end %>
    </nav>
  <% end %>

  <div class="sidebar-footer">
    <div class="sidebar-avatar sidebar-avatar-human"><%= current_user.name.first.upcase %></div>
    <div class="min-w-0 flex-1">
      <div class="truncate text-sm font-medium text-stone-800"><%= current_user.name %></div>
      <div class="text-xs text-stone-400">Signed in</div>
    </div>
    <%= button_to "Log out", session_path, method: :delete, class: "sidebar-logout", title: "Log out", aria: { label: "Log out" } %>
  </div>
</aside>
