<header class="workspace-mobile-header">
  <%= render "messages/project_switcher", project: project, projects: projects, compact: true %>
  <nav aria-label="Mobile workspace navigation">
    <%= link_to "Chat", chat_project_path(project), class: active == :chat ? "active" : nil, aria: (active == :chat ? { current: "page" } : {}) %>
    <%= link_to "Tasks", project_todos_path(project), class: active == :todos ? "active" : nil, aria: (active == :todos ? { current: "page" } : {}) %>
    <%= link_to "Agents", agents_path, class: active == :agents ? "active" : nil, aria: (active == :agents ? { current: "page" } : {}) %>
  </nav>
</header>