<header class="workspace-mobile-header">
  <%= render "chat_messages/project_switcher", project: project, projects: projects, compact: true %>
  <nav aria-label="Mobile workspace navigation">
    <%= link_to "Chat", project_chat_path(project), class: active == :chat ? "active" : nil, aria: (active == :chat ? { current: "page" } : {}) %>
    <%= link_to "Tasks", project_tasks_path(project), class: active == :tasks ? "active" : nil, aria: (active == :tasks ? { current: "page" } : {}) %>
    <%= link_to "Agents", agents_path, class: active == :agents ? "active" : nil, aria: (active == :agents ? { current: "page" } : {}) %>
  </nav>
</header>