<div id="sidebar_agent_list" class="sidebar-agent-list" aria-live="polite">
  <% agents.each do |agent| %>
    <% hosted = agent.hosted_agent %>
    <% connected = hosted ? hosted.bridge_connected? : agent.working? %>
    <% event = agent.agent_events.accepted.where(event_type: "todo_assigned").order(accepted_at: :desc).find(&:active?) %>
    <% avatar = { "hermes" => "/avatars/hermes.svg", "klaus" => "/avatars/klaus.svg", "codex" => "/avatars/codex.svg" }[agent.handle] %>
    <div class="sidebar-agent-group">
      <div class="agent-row-shell <%= 'agent-row-active' if active_agent_id == agent.id %>" data-sidebar-agent-id="<%= agent.id %>" data-agent-connected="<%= connected %>">
        <%= link_to hosted ? agent_path(agent) : agents_path, class: "agent-row", aria: { label: "#{agent.name}#{connected ? ', online' : ', offline'}" } do %>
          <div class="sidebar-avatar"><% if avatar %><%= image_tag avatar, alt: "", aria: { hidden: true } %><% else %><%= agent.name.first.upcase %><% end %><% if connected %><span class="agent-avatar-online" aria-hidden="true"></span><% end %></div>
          <span class="agent-name"><%= agent.name %></span>
          <svg class="agent-kind-mark" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.25" aria-label="Agent" role="img"><rect x="2.5" y="4.5" width="11" height="8" rx="2"/><path d="M8 2v2.5M5.5 8h.01M10.5 8h.01M5.5 10.5h5"/></svg>
        <% end %>
        <% if event %>
          <%= link_to project_todo_path(event.todo.project, event.todo), class: "agent-inline-work", title: event.todo.title, aria: { label: "Arbeitet an #{event.todo.title}" }, data: { agent_event_id: event.public_id } do %>
            <span class="agent-work-spinner" aria-hidden="true"></span>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
