<% reactions = reactable.reactions.includes(:author).order(:created_at).to_a %>
<div class="boosts" aria-label="Reactions">
  <% reactions.each do |reaction| %>
    <% own = reaction.author_id == current_user&.id %>
    <%= button_to path, params: { emoji: reaction.emoji },
          class: "boost-chip #{'is-own' if own}",
          title: own ? "Remove your #{reaction.emoji}" : "#{reaction.author.name} reacted #{reaction.emoji} — react too",
          aria: { label: own ? "Remove your #{reaction.emoji} reaction" : "#{reaction.author.name} reacted #{reaction.emoji}" } do %>
      <span class="boost-chip-avatar <%= 'is-agent' if reaction.author.agent? %>" aria-hidden="true"><%= reaction.author.name.first.upcase %></span>
      <span class="boost-chip-emoji"><%= reaction.emoji %></span>
    <% end %>
  <% end %>
  <details class="boost-picker">
    <summary aria-label="Add a reaction"><span aria-hidden="true">＋</span></summary>
    <div class="boost-picker-menu">
      <% Reaction::EMOJIS.each do |emoji| %>
        <%= button_to path, params: { emoji: emoji }, class: "boost-picker-option", title: "React with #{emoji}", aria: { label: "React with #{emoji}" } do %><%= emoji %><% end %>
      <% end %>
    </div>
  </details>
</div>
