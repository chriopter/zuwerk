<!DOCTYPE html>
<html lang="en" data-theme="corporate">
  <head>
    <title><%= content_for(:title) || "Zuwerk" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <% if Rails.env.test? %>
      <link rel="stylesheet" href="/assets/lexxy.css">
      <link rel="stylesheet" href="/assets/tailwind.css">
    <% else %>
      <%= stylesheet_link_tag "lexxy", "tailwind", "data-turbo-track": "reload" %>
    <% end %>
    <%= javascript_importmap_tags %>
  </head>
  <% workspace_page = current_user && ((controller_name == "messages" && action_name == "index") || controller_name == "agents") %>
  <% chat_page = controller_name == "messages" && action_name == "index" %>
  <% terminal_page = controller_name == "agents" && action_name == "show" %>
  <body class="<%= workspace_page ? 'h-dvh overflow-hidden bg-white' : 'min-h-screen bg-slate-50 text-slate-950 antialiased' %>">
    <% if workspace_page %>
      <div class="workspace-shell">
        <%= render "shared/workspace_sidebar",
          project: @project,
          projects: @projects,
          agents: chat_page ? @agents : @sidebar_agents,
          active: chat_page ? :chat : :agents,
          active_agent_id: @agent&.id %>
        <main class="<%= if chat_page
          'h-full min-h-0 min-w-0'
        elsif terminal_page
          'h-full min-h-0 min-w-0 overflow-hidden'
        else
          'min-h-0 min-w-0 overflow-y-auto p-4 sm:p-8'
        end %>">
          <% flash.each do |type, message| %><div class="alert <%= type == 'alert' ? 'alert-error' : 'alert-success' %> mb-4 shadow-sm" role="status"><span><%= message %></span></div><% end %>
          <%= yield %>
        </main>
      </div>
    <% else %>
      <header class="border-b border-slate-200 bg-white px-5">
        <div class="mx-auto flex h-16 max-w-6xl items-center justify-between">
          <%= link_to "Zuwerk", root_path, class: "text-lg font-bold tracking-tight text-slate-950" %>
          <% if current_user %>
            <div class="flex items-center gap-5">
              <%= link_to "Projects", root_path, class: "text-sm font-medium text-slate-500 hover:text-slate-950" %>
              <%= link_to "Agents", agents_path, class: "text-sm font-medium #{controller_name == 'agents' ? 'text-slate-950' : 'text-slate-500 hover:text-slate-950'}" %>
              <%= button_to "Log out", session_path, method: :delete, class: "text-sm font-medium text-slate-500 hover:text-slate-950" %>
            </div>
          <% end %>
        </div>
      </header>
      <main class="mx-auto w-full max-w-6xl p-4 sm:p-8">
        <% flash.each do |type, message| %><div class="alert <%= type == 'alert' ? 'alert-error' : 'alert-success' %> mb-4 shadow-sm" role="status"><span><%= message %></span></div><% end %>
        <%= yield %>
      </main>
    <% end %>
  </body>
</html>
