<% content_for :title, "#{@table} / #{@record_id} · Database · Zuwerk" %>

<section class="mx-auto max-w-[1500px]">
  <div class="grid items-start gap-6 lg:grid-cols-[220px_minmax(0,1fr)]">
    <%= render "table_navigation" %>

    <div class="min-w-0">
      <header class="mb-7">
        <p class="text-xs font-semibold uppercase tracking-[.14em] text-stone-400">Database record</p>
        <h1 class="mt-2 font-mono text-2xl font-semibold text-stone-900"><%= @table %> / <%= @record_id %></h1>
        <%= link_to "Back to #{@table}", database_table_path(@table), class: "mt-2 inline-block text-sm text-orange-700 hover:text-orange-900" %>
      </header>

      <section data-database-record class="overflow-hidden rounded-xl border border-stone-200 bg-white">
        <div class="border-b border-stone-200 px-4 py-3 text-xs font-semibold uppercase tracking-[.12em] text-stone-400">Record</div>
        <dl class="divide-y divide-stone-100">
          <% @columns.each do |column| %>
            <div class="grid gap-2 px-4 py-3 sm:grid-cols-[minmax(160px,.3fr)_minmax(0,1fr)]">
              <dt class="font-mono text-xs font-semibold text-stone-500"><%= column.name %></dt>
              <dd class="break-words font-mono text-xs text-stone-900"><%= @record[column.name].nil? ? "NULL" : @record[column.name] %></dd>
            </div>
          <% end %>
        </dl>
      </section>
    </div>
  </div>
</section>
