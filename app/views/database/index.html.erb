<% content_for :title, "Database · Zuwerk" %>

<section class="mx-auto max-w-6xl">
  <header class="mb-8">
    <p class="text-xs font-semibold uppercase tracking-[.14em] text-stone-400">System</p>
    <h1 class="mt-2 font-serif text-3xl text-stone-900">Database</h1>
    <p class="mt-2 text-sm text-stone-500">Read-only view of the primary database tables, structure and records.</p>
  </header>

  <div class="overflow-hidden rounded-xl border border-stone-200 bg-white">
    <% @tables.each do |table| %>
      <%= link_to database_table_path(table), class: "flex items-center justify-between border-b border-stone-100 px-5 py-3.5 text-sm text-stone-700 last:border-b-0 hover:bg-stone-50" do %>
        <code><%= table %></code><span class="text-stone-300">→</span>
      <% end %>
    <% end %>
  </div>
</section>
