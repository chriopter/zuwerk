<%= form_with model: [ @project, automation ], class: "board-automation-form" do |form| %>
  <% if automation.errors.any? %>
    <div id="board-form-errors" class="board-form-errors" role="alert" tabindex="-1" autofocus>
      <strong>Could not save this automation.</strong>
      <p><%= automation.errors.full_messages.to_sentence %></p>
    </div>
  <% end %>

  <% title_errors = automation.errors[:title] %>
  <div>
    <%= form.label :title, "Publication title" %>
    <%= form.text_field :title, required: true, maxlength: 160, placeholder: "Weekly project briefing", class: "input input-bordered w-full bg-white", aria: { invalid: title_errors.any?, describedby: title_errors.any? ? "board-title-error" : nil } %>
    <% if title_errors.any? %><p id="board-title-error" class="board-field-error"><%= title_errors.to_sentence %></p><% end %>
  </div>

  <div class="board-form-grid">
    <% agent_errors = automation.errors[:agent] + automation.errors[:agent_id] %>
    <div>
      <%= form.label :agent_id, "Agent" %>
      <%= form.collection_select :agent_id, @agents, :id, :name, { prompt: "Select an agent" }, required: true, class: "select select-bordered w-full bg-white", aria: { invalid: agent_errors.any?, describedby: agent_errors.any? ? "board-agent-error" : nil } %>
      <% if agent_errors.any? %><p id="board-agent-error" class="board-field-error"><%= agent_errors.to_sentence %></p><% end %>
    </div>

    <% cadence_errors = automation.errors[:cadence] %>
    <div>
      <%= form.label :cadence, "Frequency" %>
      <%= form.select :cadence, [["Every hour", "hourly"], ["Every day", "daily"], ["Every week", "weekly"], ["Every month", "monthly"]], {}, class: "select select-bordered w-full bg-white", aria: { invalid: cadence_errors.any?, describedby: cadence_errors.any? ? "board-cadence-error" : nil } %>
      <% if cadence_errors.any? %><p id="board-cadence-error" class="board-field-error"><%= cadence_errors.to_sentence %></p><% end %>
    </div>
  </div>

  <% prompt_errors = automation.errors[:prompt] %>
  <div>
    <%= form.label :prompt, "Prompt" %>
    <p id="board-prompt-hint" class="board-field-hint">Tell the selected agent what to do and what the published result should contain.</p>
    <%= form.rich_text_area :prompt, required: true, placeholder: "Review the project and publish…", aria: { invalid: prompt_errors.any?, describedby: [ "board-prompt-hint", ("board-prompt-error" if prompt_errors.any?) ].compact.join(" ") } %>
    <% if prompt_errors.any? %><p id="board-prompt-error" class="board-field-error"><%= prompt_errors.to_sentence %></p><% end %>
  </div>

  <div class="board-form-actions">
    <%= link_to "Cancel", automation.persisted? ? project_board_automation_path(@project, automation) : project_board_posts_path(@project), class: "btn btn-ghost" %>
    <%= form.submit automation.persisted? ? "Save automation" : "Create automation", class: "btn bg-stone-900 text-white hover:bg-stone-700" %>
  </div>
<% end %>
