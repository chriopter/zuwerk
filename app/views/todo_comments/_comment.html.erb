<article id="<%= dom_id(comment) %>" class="border-t border-stone-100 py-5">
  <header class="mb-2 flex items-center gap-2 text-xs text-stone-400">
    <strong class="text-stone-700"><%= comment.author.name %></strong>
    <time><%= comment.created_at.strftime("%d.%m.%Y · %H:%M") %></time>
    <% if comment.author == current_user %>
      <span class="ml-auto flex gap-3">
        <%= link_to "Edit", edit_project_todo_comment_path(@project, @todo, comment), class: "hover:text-stone-800" %>
        <%= button_to "Delete", project_todo_comment_path(@project, @todo, comment), method: :delete, class: "hover:text-red-600", form: { data: { turbo_confirm: "Delete comment?" } } %>
      </span>
    <% end %>
  </header>
  <div class="lexxy-content text-sm text-stone-700"><%= comment.body %></div>
</article>
