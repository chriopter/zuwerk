<article id="<%= dom_id(comment) %>" class="border-t border-stone-100 py-5">
  <header class="mb-2 flex items-center gap-2 text-xs text-stone-400">
    <strong class="text-stone-700"><%= comment.author.name %></strong>
    <time><%= comment.created_at.strftime("%d.%m.%Y · %H:%M") %></time>
    <% if comment.author == current_user %>
      <span class="comment-actions">
        <%= link_to edit_project_todo_comment_path(@project, @todo, comment), class: "comment-icon-action", title: "Kommentar bearbeiten", aria: { label: "Kommentar bearbeiten" } do %><%= render "shared/icon", name: "edit" %><% end %>
        <%= button_to project_todo_comment_path(@project, @todo, comment), method: :delete, class: "comment-icon-action hover:text-red-600", title: "Kommentar löschen", aria: { label: "Kommentar löschen" }, form: { data: { turbo_confirm: "Kommentar löschen?" } } do %><%= render "shared/icon", name: "trash" %><% end %>
      </span>
    <% end %>
  </header>
  <div class="lexxy-content text-sm text-stone-700"><%= comment.body %></div>
  <%= render "reactions/reactions", reactable: comment, current_user: current_user, path: project_todo_comment_reactions_path(@project, @todo, comment) %>
</article>
