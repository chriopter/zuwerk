<%= form_with model: [ @project, task ], class: "space-y-5" do |form| %>
  <% if task.errors.any? %><p class="text-sm text-red-600"><%= task.errors.full_messages.to_sentence %></p><% end %>
  <div>
    <%= form.label :title, class: "mb-1 block text-xs font-semibold uppercase tracking-wide text-stone-500" %>
    <%= form.text_field :title, required: true, maxlength: 160, class: "input input-bordered w-full bg-white" %>
  </div>
  <div>
    <%= form.label :status, "Status", class: "mb-1 block text-xs font-semibold uppercase tracking-wide text-stone-500" %>
    <%= form.select :status, [["Offen", "open"], ["Erledigt", "completed"]], {}, class: "select select-bordered w-full bg-white" %>
  </div>
  <div>
    <%= form.label :parent_id, "Parent", class: "mb-1 block text-xs font-semibold uppercase tracking-wide text-stone-500" %>
    <% excluded_parent_ids = task.persisted? ? task.subtree_ids : [] %>
    <%= form.collection_select :parent_id, @project.tasks.where.not(id: excluded_parent_ids).ordered, :id, :title, { include_blank: "Top level" }, class: "select select-bordered w-full bg-white" %>
  </div>
  <div>
    <%= form.label :description, class: "mb-1 block text-xs font-semibold uppercase tracking-wide text-stone-500" %>
    <%= form.rich_text_area :description, placeholder: "Context, files, links and acceptance criteria…" %>
  </div>
  <div class="flex justify-end gap-3">
    <%= link_to "Cancel", task.persisted? ? project_task_path(@project, task) : project_tasks_path(@project), class: "btn btn-ghost" %>
    <%= form.submit class: "btn bg-stone-900 text-white hover:bg-stone-700" %>
  </div>
<% end %>
