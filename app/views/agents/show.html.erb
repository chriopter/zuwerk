<% content_for :title, "#{@agent.name} · Zuwerk" %>
<% avatar = { "hermes" => "/avatars/hermes.svg", "klaus" => "/avatars/klaus.svg", "codex" => "/avatars/codex.svg" }[@agent.handle] %>

<div class="agent-cockpit">
  <%= link_to "← All agents", agents_path, class: "agents-back-link" %>

  <section class="agent-overview-grid" aria-label="Agent overview">
    <article class="agent-overview-card agent-identity-card">
      <span>Agent</span>
      <div class="agent-identity">
        <div class="agent-detail-avatar"><% if avatar %><%= image_tag avatar, alt: "" %><% else %><%= @agent.name.first.upcase %><% end %></div>
        <div class="min-w-0">
          <h1><%= @agent.name %></h1>
          <p><%= @hosted_agent.runtime == "claude" ? "Claude Code" : "Codex" %> · Hosted</p>
        </div>
      </div>
    </article>

    <article class="agent-overview-card">
      <span>Runtime</span>
      <strong><i class="status-light status-light-runtime"></i><%= @hosted_agent.state.humanize %></strong>
      <p class="truncate" title="<%= @hosted_agent.container_name %>"><%= @hosted_agent.container_name %></p>
    </article>

    <article class="agent-overview-card <%= 'agent-overview-card-warning' unless @hosted_agent.bridge_connected? %>">
      <span>Connection</span>
      <% if @hosted_agent.bridge_connected? %>
        <strong data-chat-bridge-status><i class="status-light status-light-online"></i>Connected</strong>
        <p>Persistent ACP session available.</p>
      <% else %>
        <strong data-chat-bridge-status><i class="status-light status-light-offline"></i>Not connected</strong>
        <p>Runtime available without chat connection.</p>
        <%= link_to "Create invitation", new_agent_invitation_path, class: "agent-connect-link" %>
      <% end %>
    </article>

    <article class="agent-overview-card">
      <span>Workspace</span>
      <strong>Persistent</strong>
      <p>Home, login and files survive restarts.</p>
    </article>
  </section>

  <div class="agent-toolbar" aria-label="Runtime controls">
    <%= button_to "Start", start_agent_path(@agent), disabled: @hosted_agent.running? %>
    <%= button_to "Restart", restart_agent_path(@agent) %>
    <%= button_to "Stop", stop_agent_path(@agent), disabled: @hosted_agent.stopped? %>
  </div>

  <% if @hosted_agent.last_error.present? %>
    <div class="agents-form-errors"><strong>Container error:</strong> <%= @hosted_agent.last_error %></div>
  <% end %>

  <section class="agent-sessions" aria-labelledby="cloud-sessions-heading">
    <div class="agent-section-heading">
      <div>
        <span id="cloud-sessions-heading">Cloud sessions</span>
        <p>Resumable conversations and their workspace origin.</p>
      </div>
      <% if @cloud_sessions.any? %><small><%= pluralize(@cloud_sessions.size, "session") %></small><% end %>
    </div>

    <% if @cloud_sessions.any? %>
      <div class="agent-session-list">
        <%= render partial: "agents/cloud_session", collection: @cloud_sessions.first(5), as: :session, locals: { hosted_agent: @hosted_agent } %>
      </div>
      <% if @cloud_sessions.size > 5 %>
        <details class="agent-session-archive">
          <summary>Show <%= @cloud_sessions.size - 5 %> older sessions <i aria-hidden="true">⌄</i></summary>
          <div class="agent-session-list">
            <%= render partial: "agents/cloud_session", collection: @cloud_sessions.drop(5), as: :session, locals: { hosted_agent: @hosted_agent } %>
          </div>
        </details>
      <% end %>
    <% else %>
      <p class="agent-sessions-empty">No cloud sessions yet.</p>
    <% end %>
  </section>

  <details class="agent-terminal-disclosure">
    <summary>
      <span>Live terminal</span>
      <small>Optional · persistent tmux session</small>
      <i aria-hidden="true">⌄</i>
    </summary>
    <div class="agent-terminal-disclosure-body">
      <div class="terminal-cockpit" data-terminal-agent-id="<%= @agent.id %>" data-terminal-enabled="<%= @hosted_agent.running? %>">
        <div class="terminal-titlebar">
          <div><i></i><i></i><i></i></div>
          <span>agent · <%= @hosted_agent.runtime %> · live websocket</span>
          <button type="button" data-terminal-reconnect>Reconnect</button>
        </div>
        <div class="terminal-screen terminal-screen-compact" data-terminal-screen tabindex="0" aria-label="Interactive agent terminal"></div>
      </div>
    </div>
  </details>
</div>
