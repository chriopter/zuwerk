<% content_for :title, "#{@agent.name} · Zuwerk" %>

<div class="agent-terminal-page">
  <header class="agent-terminal-header">
    <div class="min-w-0">
      <div class="flex items-center gap-2">
        <h1><%= @agent.name %></h1>
        <span class="agents-status agents-status-<%= @hosted_agent.state %>"><i></i><%= @hosted_agent.state.humanize %></span>
      </div>
      <p><%= @hosted_agent.runtime == "claude" ? "Claude Code" : "Codex" %> · <%= @hosted_agent.container_name %> · <span data-chat-bridge-status>Chat bridge: Not connected</span></p>
    </div>

    <div class="agent-terminal-actions">
      <%= button_to "Start", start_agent_path(@agent), disabled: @hosted_agent.running? %>
      <%= button_to "Restart", restart_agent_path(@agent) %>
      <%= button_to "Stop", stop_agent_path(@agent), disabled: @hosted_agent.stopped? %>
    </div>
  </header>

  <% if @hosted_agent.last_error.present? %>
    <div class="agents-form-errors"><strong>Container error:</strong> <%= @hosted_agent.last_error %></div>
  <% end %>

  <section class="terminal-cockpit terminal-cockpit-fullscreen" data-terminal-agent-id="<%= @agent.id %>" data-terminal-enabled="<%= @hosted_agent.running? %>">
    <div class="terminal-titlebar">
      <div><i></i><i></i><i></i></div>
      <span>agent · <%= @hosted_agent.runtime %> · live websocket</span>
      <button type="button" data-terminal-reconnect>Reconnect</button>
    </div>
    <div class="terminal-screen terminal-screen-fullscreen" data-terminal-screen tabindex="0" aria-label="Interactive agent terminal"></div>
  </section>
</div>
