<% content_for :title, "New agent · Zuwerk" %>

<div class="agents-page agents-form-page">
  <header class="agents-page-header">
    <div>
      <p class="agents-kicker">On this server</p>
      <h1>Create agent</h1>
      <p>Start a persistent Claude Code or Codex environment in an isolated container.</p>
    </div>
    <%= link_to "Back", agents_path, class: "agents-secondary-action" %>
  </header>

  <% if @errors.present? %>
    <div class="agents-form-errors"><%= @errors.to_sentence %></div>
  <% end %>

  <%= form_with url: agents_path, scope: :agent, class: "agents-form" do |form| %>
    <label>
      <span>Name</span>
      <%= form.text_field :name, required: true, maxlength: 80, placeholder: "Builder" %>
    </label>
    <fieldset>
      <legend>Runtime</legend>
      <label class="runtime-choice">
        <%= form.radio_button :runtime, "claude", checked: true %>
        <span><strong>Claude Code</strong><small>Anthropic CLI with a persistent workspace</small></span>
      </label>
      <label class="runtime-choice">
        <%= form.radio_button :runtime, "codex" %>
        <span><strong>Codex</strong><small>OpenAI Codex CLI with a persistent workspace</small></span>
      </label>
    </fieldset>
    <fieldset>
      <legend>Shared folder</legend>
      <label class="runtime-choice">
        <%= form.check_box :shared_folder %>
        <span>
          <strong>Mount the host folder</strong>
          <small>Gives the agent read-write access to <%= HostedAgents::ContainerRuntime.shared_folder_source %> at <%= HostedAgents::ContainerRuntime::SHARED_MOUNT_PATH %>.</small>
        </span>
      </label>
    </fieldset>
    <fieldset>
      <legend>Autonomy</legend>
      <label class="runtime-choice">
        <%= form.check_box :autonomous %>
        <span>
          <strong>Work without asking</strong>
          <small>Skips the approval prompt before each action. The agent can then change files and run commands on its own.</small>
        </span>
      </label>
    </fieldset>
    <div class="agents-form-actions">
      <%= link_to "Cancel", agents_path %>
      <%= form.submit "Create agent", class: "agents-primary-action" %>
    </div>
  <% end %>
</div>
