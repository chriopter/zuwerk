<article class="agent-session-row" data-cloud-session>
  <div class="agent-session-origin">
    <% if session.origin.is_a?(Project) %>
      <%= link_to session.origin_label, chat_project_path(session.origin) %>
    <% elsif session.origin.is_a?(Todo) %>
      <%= link_to session.origin_label, project_todo_path(session.origin.project, session.origin) %>
    <% else %>
      <strong><%= session.origin_label %></strong>
    <% end %>
    <span><%= session.origin_type %> · <%= hosted_agent.runtime.humanize %></span>
  </div>
  <div class="agent-session-state">
    <span class="agent-session-badge"><%= session.external_session_id.present? ? "Resumable" : "Unavailable" %></span>
    <time datetime="<%= session.last_used_at.iso8601 %>">Used <%= time_ago_in_words(session.last_used_at) %> ago</time>
  </div>
  <code title="<%= session.external_session_id %>"><%= session.external_session_id.presence || "No external session" %></code>
</article>
