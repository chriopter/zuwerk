<% content_for :title, "Agents · Zuwerk" %>

<div class="agents-page">
  <header class="agents-page-header">
    <div>
      <p class="agents-kicker">Workspace</p>
      <h1>Agents</h1>
      <p>Connect agents that run in environments you control.</p>
    </div>
  </header>

  <section class="agents-section" aria-labelledby="add-agent-heading">
    <div class="agents-section-heading">
      <div><h2 id="add-agent-heading">Add an agent</h2><p>Choose a runtime. Zuwerk creates a tailored setup prompt for it.</p></div>
    </div>
    <div class="agent-profile-grid">
      <% @agent_profiles.each do |profile| %>
        <article class="agent-profile-card" data-agent-profile="<%= profile.id %>">
          <div class="agent-profile-mark agent-profile-mark-<%= profile.id %>" aria-hidden="true"><%= profile.name.first %></div>
          <div>
            <h3><%= profile.name %></h3>
            <p><%= profile.description %></p>
          </div>
          <code><%= profile.connect_command %></code>
          <%= button_to "Add #{profile.name}", agent_invitations_path, params: { profile: profile.id }, class: "agent-profile-action" %>
        </article>
      <% end %>
    </div>
  </section>

  <section class="agents-section" aria-labelledby="connected-agents-heading">
    <div class="agents-section-heading">
      <div><h2 id="connected-agents-heading">Connected agents</h2><p>Agent runtimes connect through the Zuwerk CLI and ACP.</p></div>
      <span><%= pluralize(@agents.size, "agent") %></span>
    </div>
    <div class="agents-list">
      <% @agents.each do |agent| %>
        <% sessions = @sessions_by_agent.fetch(agent.id, []) %>
        <details class="agents-row" data-agent-id="<%= agent.id %>" data-agent-origin="external">
          <summary class="agents-row-summary">
            <div class="agents-avatar"><%= agent.name.first.upcase %></div>
            <div class="agents-row-copy">
              <% connected = agent.external_connector_present? %>
              <div class="agents-name-line"><h3><%= agent.name %></h3><span class="agents-status <%= agent.working? ? 'agents-status-working' : connected ? 'agents-status-online' : 'agents-status-offline' %>"><i></i><%= agent.working? ? "Working" : connected ? "Online" : "Offline" %></span></div>
              <p>
                External environment · ACP via Zuwerk CLI
                <span class="agents-model">Model: <%= agent.connector_model.presence || "Not reported" %></span>
              </p>
              <% if agent.working? %><small><%= agent.working_label.presence || "Working" %></small><% end %>
            </div>
            <span class="agents-session-count"><%= pluralize(sessions.size, "session") %></span>
            <span class="agents-row-chevron" aria-hidden="true">⌄</span>
          </summary>
          <div class="agents-sessions">
            <% if sessions.any? %>
              <% sessions.each do |session| %>
                <%= link_to agent_session_path(session), class: "agents-session-row", data: { agent_session_id: session.id } do %>
                  <span class="agents-session-kind"><%= agent_session_kind(session) %></span>
                  <span class="agents-session-copy">
                    <strong><%= agent_session_label(session) %></strong>
                    <small><%= session.project.name %> · <%= pluralize(session.prompt_count, "prompt") %> · used <%= time_ago_in_words(session.last_used_at) %> ago</small>
                  </span>
                  <code title="<%= session.external_session_id %>"><%= session.external_session_id %></code>
                <% end %>
              <% end %>
            <% else %>
              <p class="agents-sessions-empty">No ACP sessions yet. A session appears after this agent receives its first prompt in a chat, task, or briefing.</p>
            <% end %>
          </div>
        </details>
      <% end %>
      <% if @agents.empty? %>
        <div class="agents-empty"><h3>No agents yet</h3><p>Choose Claude, Codex, or Hermes above to create an invitation.</p></div>
      <% end %>
    </div>
  </section>

  <section class="agents-section" aria-labelledby="prompt-templates-heading">
    <div class="agents-section-heading">
      <div><h2 id="prompt-templates-heading">ACP master prompt</h2><p>One shared envelope with type-specific context, tools, actions, and response instructions.</p></div>
      <span>1 template</span>
    </div>
    <article
      class="agent-master-template"
      data-controller="prompt-preview"
      data-prompt-preview-prompts-value="<%= @prompt_previews.to_json %>"
      data-prompt-preview-descriptions-value="<%= @prompt_types.to_h { |type| [ type.id, type.description ] }.to_json %>">
      <header>
        <div>
          <label for="prompt-preview-type">Situation</label>
          <select id="prompt-preview-type" data-prompt-preview-target="select" data-action="change->prompt-preview#update">
            <%= options_for_select(@prompt_types.map { |type| [ type.name, type.id ] }) %>
          </select>
        </div>
        <span data-prompt-preview-target="description"><%= @prompt_types.first.description %></span>
        <small>Preview only — no agent event is created.</small>
      </header>
      <pre data-prompt-preview-target="output"><%= @prompt_previews.fetch(:chat) %></pre>
      <details class="agent-master-source">
        <summary>View master template with placeholders</summary>
        <pre><%= @prompt_template.body %></pre>
      </details>
    </article>
  </section>
</div>
