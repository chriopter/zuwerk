<details class="project-switcher <%= 'project-switcher-compact' if local_assigns[:compact] %>">
  <summary>
    <span class="project-switcher-copy">
      <span class="project-switcher-label">Project</span>
      <strong><%= project.name %></strong>
    </span>
    <span class="project-switcher-chevron" aria-hidden="true">⌄</span>
  </summary>
  <div class="project-switcher-menu">
    <div class="project-switcher-menu-label">Projects</div>
    <div class="project-switcher-list">
      <% projects.each do |item| %>
        <%= link_to chat_project_path(item), class: "project-switcher-option #{'project-switcher-option-active' if item == project}" do %>
          <span><%= item.name %></span>
          <% if item == project %><span aria-hidden="true">✓</span><% end %>
        <% end %>
      <% end %>
    </div>
    <div class="project-switcher-create">
      <%= form_with model: Project.new, url: projects_path do |form| %>
        <%= form.label :name, "New project", class: "project-switcher-menu-label" %>
        <div class="project-switcher-create-row">
          <%= form.text_field :name, placeholder: "Project name", maxlength: 80, required: true, aria: { label: "New project name" } %>
          <%= form.submit "Add" %>
        </div>
      <% end %>
    </div>
  </div>
</details>
