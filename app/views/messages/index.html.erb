<%= turbo_stream_from @project.message_stream %>
<%= turbo_stream_from @project.agent_turn_stream %>
<%= turbo_stream_from "agent_presence" %>

<section class="chat-panel" data-controller="chat-scroll">
    <header class="chat-header">
      <nav class="workspace-breadcrumb" aria-label="Breadcrumb">
        <%= link_to @project.name, project_path(@project) %><span aria-hidden="true">/</span><span aria-current="page">Chat</span>
      </nav>
      <h1 class="sr-only">Chat</h1>

      <div class="chat-header-actions">
        <details class="notify-menu">
          <summary class="tb-pill-hit" aria-label="Configure automatic agent notifications"><span class="tb-pill"><span aria-hidden="true">✦</span><span>Notify</span></span></summary>
          <div class="notify-menu-popover">
            <div><strong>Automatic replies</strong><small>Choose which agents receive every message.</small></div>
            <% @agents.each do |agent| %>
              <% enabled = @auto_notify_agent_ids.include?(agent.id) %>
              <%= form_with url: project_agent_subscription_path(@project, agent), method: :patch do %>
                <%= hidden_field_tag :enabled, enabled ? "0" : "1" %>
                <button type="submit" class="notify-agent-row" aria-pressed="<%= enabled %>">
                  <span class="notify-agent-avatar"><%= agent.name.first.upcase %></span>
                  <span><strong><%= agent.name %></strong><small><%= enabled ? "Receives every message" : "Mentions only" %></small></span>
                  <i class="notify-switch <%= 'is-enabled' if enabled %>" aria-hidden="true"></i>
                </button>
              <% end %>
            <% end %>
          </div>
        </details>
        <%= link_to new_agent_invitation_path, class: "pill-primary", aria: { label: "Invite agent" }, title: "Invite agent" do %>
          <span aria-hidden="true">＋</span><span class="hidden sm:inline">Invite agent</span>
        <% end %>
      </div>
    </header>

    <%= render "agent_events/project_status", project: @project %>

    <div class="mobile-agent-presence">
      <%= render "agent_presence", agents: @agents %>
    </div>

    <div class="message-stage">
      <div id="message-viewport" class="message-scroll" data-chat-scroll-target="viewport" data-action="scroll->chat-scroll#track">
        <div id="messages" class="message-feed" data-controller="own-messages" data-own-messages-user-value="<%= current_user.id %>">
          <% if @messages.empty? %>
            <div class="empty-conversation">
              <div class="empty-icon">Z</div>
              <h2>Start the shared chat</h2>
              <p>Write a message or invite an agent to begin working together.</p>
            </div>
          <% end %>
          <%= render @messages, current_user: current_user %>
        </div>
      </div>
      <button type="button" class="new-message-button hidden" data-chat-scroll-target="button" data-action="chat-scroll#scrollToBottom">New messages <span aria-hidden="true">↓</span></button>
    </div>

    <div class="composer-dock">
      <%= form_with model: [@project, @message], class: "composer-form" do |form| %>
        <%= render "shared/errors", object: @message %>
        <div class="composer-box">
          <%= form.text_area :body, placeholder: "Write a message…", required: true, rows: 1, maxlength: 4000, class: "composer-input", data: { controller: "composer", action: "input->composer#grow keydown->composer#keydown" }, aria: { label: "Message" } %>
          <div class="composer-footer">
            <div class="composer-tools">
              <%= form.file_field :attachments, multiple: true, class: "composer-file-input", accept: "image/*,.pdf,.txt,.md,.csv,.json,.zip", aria: { label: "Attach files" } %>
              <span class="hidden sm:inline">Markdown supported · up to 5 files</span>
            </div>
            <span class="sm:hidden"></span>
            <%= form.submit "Send", class: "send-button" %>
          </div>
        </div>
      <% end %>
    </div>
</section>
