<%= turbo_stream_from @project.message_stream %>
<%= turbo_stream_from "agent_presence" %>

<div class="workspace-shell" data-controller="chat-scroll">
  <aside class="workspace-sidebar">
    <%= render "project_switcher", project: @project, projects: @projects %>

    <nav class="sidebar-navigation" aria-label="Chat navigation">
      <div class="sidebar-label">Conversation</div>
      <%= link_to chat_project_path(@project), class: "sidebar-channel sidebar-channel-active", aria: { current: "page" } do %>
        <span>Shared chat</span>
      <% end %>
      <%= link_to agents_path, class: "sidebar-channel mt-1" do %>
        <span>Agents</span>
      <% end %>
    </nav>

    <section class="sidebar-agents" aria-labelledby="agents-heading">
      <div id="agents-heading" class="sidebar-label">Agents</div>
      <div class="sidebar-agent-list">
        <% @agents.each do |agent| %>
          <div class="agent-row">
            <div class="relative">
              <div class="sidebar-avatar"><%= agent.name.first.upcase %></div>
              <span class="agent-dot <%= agent.working? ? 'agent-dot-working' : 'agent-dot-idle' %>"></span>
            </div>
            <div class="min-w-0 flex-1">
              <div class="truncate text-sm font-medium text-stone-800"><%= agent.name %></div>
              <div class="truncate text-xs text-stone-400"><%= agent.working? ? (agent.working_label.presence || "Working") : "Available" %></div>
            </div>
          </div>
        <% end %>
      </div>
      <%= link_to new_agent_invitation_path, class: "sidebar-invite" do %>
        <span aria-hidden="true">＋</span><span>Invite agent</span>
      <% end %>
    </section>

    <div class="sidebar-footer">
      <div class="sidebar-avatar sidebar-avatar-human"><%= current_user.name.first.upcase %></div>
      <div class="min-w-0 flex-1">
        <div class="truncate text-sm font-medium text-stone-800"><%= current_user.name %></div>
        <div class="text-xs text-stone-400">Signed in</div>
      </div>
      <%= button_to "Log out", session_path, method: :delete, class: "sidebar-logout", title: "Log out", aria: { label: "Log out" } %>
    </div>
  </aside>

  <section class="chat-panel">
    <header class="chat-header-bar">
      <div class="min-w-0 lg:block">
        <div class="mobile-project-context lg:hidden">
          <%= render "project_switcher", project: @project, projects: @projects, compact: true %>
        </div>
        <h1 class="hidden lg:block">Shared chat</h1>
      </div>

      <div class="chat-header-actions">
        <%= link_to "Agents", agents_path, class: "header-action" %>
        <%= form_with model: @room_setting, url: project_room_setting_path(@project), method: :patch, class: "notify-control" do |form| %>
          <div class="notify-copy">
            <div class="notify-title">Notify</div>
            <div class="notify-subtitle"><%= @room_setting.notify_agents? ? "Every human message" : "Mentions only" %></div>
          </div>
          <%= form.check_box :notify_agents, class: "toggle toggle-sm", onchange: "this.form.requestSubmit()", aria: { label: "Notify all agents about human messages" } %>
        <% end %>
        <%= link_to new_agent_invitation_path, class: "header-action", aria: { label: "Invite agent" }, title: "Invite agent" do %>
          <span aria-hidden="true">＋</span><span class="hidden sm:inline">Invite agent</span>
        <% end %>
        <%= button_to "Exit", session_path, method: :delete, class: "mobile-logout lg:hidden", title: "Log out", aria: { label: "Log out" } %>
      </div>
    </header>

    <div class="mobile-agent-presence">
      <%= render "agent_presence", agents: @agents %>
    </div>

    <div class="message-stage">
      <div id="message-viewport" class="message-scroll" data-chat-scroll-target="viewport" data-action="scroll->chat-scroll#track">
        <div id="messages" class="message-feed">
          <% if @messages.empty? %>
            <div class="empty-conversation">
              <div class="empty-icon">Z</div>
              <h2>Start the shared chat</h2>
              <p>Write a message or invite an agent to begin working together.</p>
            </div>
          <% end %>
          <%= render @messages, current_user: current_user %>
        </div>
      </div>
      <button type="button" class="new-message-button hidden" data-chat-scroll-target="button" data-action="chat-scroll#scrollToBottom">New messages <span aria-hidden="true">↓</span></button>
    </div>

    <div class="composer-dock">
      <%= form_with model: [@project, @message], class: "composer-form" do |form| %>
        <%= render "shared/errors", object: @message %>
        <div class="composer-box">
          <%= form.text_area :body, placeholder: "Write a message…", required: true, rows: 1, maxlength: 4000, class: "composer-input", data: { controller: "composer", action: "input->composer#grow keydown->composer#keydown" }, aria: { label: "Message" } %>
          <div class="composer-footer">
            <span class="hidden sm:inline">Shift + Enter for a new line</span>
            <span class="sm:hidden"></span>
            <%= form.submit "Send", class: "send-button" %>
          </div>
        </div>
      <% end %>
    </div>
  </section>
</div>
