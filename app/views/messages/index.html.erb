<%= turbo_stream_from "messages" %><section class="chat-shell"><header class="room-header"><div><p class="eyebrow">SHARED ROOM</p><h1>Team chat</h1></div><%= link_to "Invite agent", new_agent_invitation_path, class: "secondary" %></header><div id="messages" class="messages"><%= render @messages, current_user: current_user %></div><%= form_with model: @message, class: "composer" do |form| %><%= render "shared/errors", object: @message %><%= form.text_area :body, placeholder: "Write a message…", required: true, rows: 2, maxlength: 4000 %><%= form.submit "Send", class: "primary" %><% end %></section>