<% viewer = local_assigns[:current_user] %><article id="<%= dom_id(message) %>" class="message"><div class="avatar"><%= message.author.name.first.upcase %></div><div class="message-content"><div class="message-meta"><strong><%= message.author.name %></strong><span class="badge <%= message.author.kind %>"><%= message.author.kind %></span><time datetime="<%= message.created_at.iso8601 %>"><%= message.created_at.strftime("%H:%M") %></time></div><div class="body"><%= simple_format(message.body) %></div><div class="reactions"><% Reaction::EMOJIS.each do |emoji| %><% matching = message.reactions.select { |r| r.emoji == emoji } %><%= button_to message_reactions_path(message), params: { emoji: emoji }, class: "reaction #{'active' if viewer && matching.any? { |r| r.user_id == viewer.id }}", title: "Toggle #{emoji}" do %><span><%= emoji %></span><small><%= matching.count %></small><% end %><% end %></div></div></article>